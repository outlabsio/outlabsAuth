# ============================================================================
# Required Configuration
# ============================================================================

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017

# Database name
MONGO_DB=outlabs_auth_notifications

# Secret key for JWT tokens (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=dev-secret-key-change-this-in-production

# ============================================================================
# Webhook Channel (Optional)
# ============================================================================

# Webhook URL to receive notifications
# Test with: https://webhook.site (get a free unique URL)
WEBHOOK_URL=

# Optional authentication token for webhook
WEBHOOK_TOKEN=

# ============================================================================
# SMTP Email Channel (Optional)
# ============================================================================

# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMTP authentication
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email addresses
FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ============================================================================
# Telegram Channel (Optional)
# ============================================================================

# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID (your user ID or group chat ID)
TELEGRAM_CHAT_ID=

# ============================================================================
# RabbitMQ Channel (Optional)
# ============================================================================

# RabbitMQ connection string
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ============================================================================
# SendGrid Email Channel (Optional alternative to SMTP)
# ============================================================================

# SendGrid API key
SENDGRID_API_KEY=

# ============================================================================
# Twilio SMS/WhatsApp Channels (Optional)
# ============================================================================

# Twilio account credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio phone number (for SMS)
TWILIO_FROM_NUMBER=+1234567890

# Twilio WhatsApp number (format: whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=

# ============================================================================
# Notes
# ============================================================================

# All notification channels are optional. The example will work with any combination.
# Simply configure the channels you want to use by setting their environment variables.

# For testing:
# - Webhook: Use https://webhook.site for free testing
# - Email: Use Gmail with App Password or Mailtrap for testing
# - Telegram: Create a bot with @BotFather
# - RabbitMQ: Run with Docker: docker run -d -p 5672:5672 rabbitmq:3
