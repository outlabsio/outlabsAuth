FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8004

# Optional: mount Google invite-only login + account linking.
# Authorized redirect URIs in Google Cloud Console must include both:
#   {API_PUBLIC_URL}/v1/oauth/google/callback
#   {API_PUBLIC_URL}/v1/oauth-associate/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Transactional mail provider: auto|mailgun|sendgrid|postmark|resend|smtp|webhook|console
# auto picks the first fully configured provider, else console.
OUTLABS_AUTH_MAIL_PROVIDER=auto
MAIL_FROM_NAME=Outlabs Auth Sandbox

# Shared sandbox redirect for any provider (preferred). MAILGUN_RECIPIENT_OVERRIDE still works.
# MAIL_RECIPIENT_OVERRIDE=system@outlabs.io

# --- Mailgun ---
MAILGUN_API_BASE_URL=https://api.mailgun.net
MAILGUN_DOMAIN=sandboxff2ad6041f7a4833b4ca6e5080732e28.mailgun.org
MAILGUN_API_KEY=replace-with-your-mailgun-api-key
MAILGUN_FROM_EMAIL=postmaster@sandboxff2ad6041f7a4833b4ca6e5080732e28.mailgun.org
# MAILGUN_FROM_NAME=Outlabs Auth Sandbox
# MAILGUN_RECIPIENT_OVERRIDE=system@outlabs.io

# --- SendGrid ---
# SENDGRID_API_KEY=
# MAIL_FROM=noreply@example.com

# --- Postmark (same family of host recipes as qdarte outreach) ---
# POSTMARK_SERVER_TOKEN=
# POSTMARK_FROM_EMAIL=noreply@example.com
# POSTMARK_MESSAGE_STREAM=outbound

# --- Resend ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@example.com

# --- SMTP ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_USE_STARTTLS=true
# SMTP_USE_SSL_TLS=false

# --- Webhook (forward to your own worker) ---
# OUTLABS_AUTH_MAIL_WEBHOOK_URL=
# OUTLABS_AUTH_MAIL_WEBHOOK_SECRET=

# --- Twilio challenge messaging (WhatsApp Content API + SMS Messages) ---
# Shared account credentials:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# WhatsApp (Content template SID required for live send):
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_ACCESS_CODE_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_REQUIRE_VERIFIED=false
# SMS (E.164 From number; enables sms_otp / phone_verify over SMS):
# TWILIO_SMS_FROM=+15551234567

