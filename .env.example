# PostgreSQL Configuration
# The asyncpg driver is required — outlabs-auth is async-only.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/outlabs_auth

# Schema the auth tables live in. Applied via search_path on the connection;
# outlabs-auth keeps its own alembic history here (outlabs_auth_alembic_version),
# separate from any schema your app owns.
OUTLABS_AUTH_SCHEMA=outlabs_auth

# JWT Configuration
# Must be at least 32 characters for HS256 — shorter values are rejected at
# construction. Generate a real one; do NOT ship this placeholder, it is long
# enough to pass the length check and would sign forgeable tokens:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE-ME-generate-with-secrets.token_urlsafe(48)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# System Email Configuration (for admin notifications only)
# Example for Gmail (requires app password)
SYSTEM_SMTP_HOST=smtp.gmail.com
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=your-email@gmail.com
SYSTEM_SMTP_PASSWORD=your-app-password
SYSTEM_SMTP_USE_TLS=true
SYSTEM_EMAIL_FROM=noreply@yourdomain.com
SYSTEM_EMAIL_FROM_NAME=Outlabs Auth System

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# Redis Configuration (optional — for rate limiting and caching).
# Setting REDIS_URL alone ENABLES Redis, which from 0.1.0a24 makes
# redis_key_prefix mandatory. Namespace it per app+environment so two
# deployments can't share keys (e.g. outlabs-auth:production:billing-api).
REDIS_URL=redis://localhost:6379