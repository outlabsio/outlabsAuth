# OutlabsAuth Observability Stack Configuration
# Copy this file to .env and customize for your project
#
# Usage:
#   cp .env.example .env
#   ./setup.sh
#   docker compose up -d

# =============================================================================
# Project Settings
# =============================================================================

# Project name - used as prefix for container and volume names
# Example: myproject -> myproject-prometheus, myproject-grafana, etc.
PROJECT_NAME=outlabs

# Environment label added to all metrics
ENVIRONMENT=development

# =============================================================================
# Your API Configuration
# =============================================================================

# Host where your FastAPI app is running
# - For local dev (app on host, observability in Docker): host.docker.internal
# - For Docker-to-Docker: use container name or network alias
# - For production: your actual hostname/IP
API_HOST=host.docker.internal

# Port your FastAPI app is running on
API_PORT=8000

# Metrics endpoint path (default: /metrics)
API_METRICS_PATH=/metrics

# =============================================================================
# Observability Stack Ports
# =============================================================================
# Change these if you have port conflicts or running multiple stacks

# Grafana - Dashboards and visualization
GRAFANA_PORT=3011

# Prometheus - Metrics collection
PROMETHEUS_PORT=9090

# Loki - Log aggregation
LOKI_PORT=3100

# Tempo - Distributed tracing
TEMPO_PORT=3200
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318

# =============================================================================
# Grafana Settings
# =============================================================================

# Admin password (change in production!)
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# Prometheus Settings
# =============================================================================

# How long to keep metrics data
PROMETHEUS_RETENTION=15d

# Scrape interval (how often to collect metrics)
PROMETHEUS_SCRAPE_INTERVAL=10s
